  "description": "Auto-detect your project's tech stack and install matching coding rules into Claude Code, Codex, and Cursor.",
  "type": "module",
  "license": "MIT",
  "author": "Chasen Liao (https://github.com/Chasen-Liao)",
  "homepage": "https://github.com/Chasen-Liao/rules-aio#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Chasen-Liao/rules-aio.git"
  },
  "bugs": {
    "url": "https://github.com/Chasen-Liao/rules-aio/issues"
  },
  "keywords": [
    "claude-code",
    "codex",
    "cursor",
    "cursorrules",
    "rules",
    "cli",
    "ai-coding",
    "agent-rules"
